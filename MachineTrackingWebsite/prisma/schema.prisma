generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  user
}

model PendingUser {
  id            String   @id @default(cuid())
  email         String   @unique
  password_hash String
  requested_at  DateTime @default(now())
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password_hash String
  role          Role      @default(user)
  created_at    DateTime  @default(now())
  sessions      Session[]
}

model Session {
  id         String   @id @default(cuid())
  user_id    String
  user       User     @relation(fields: [user_id], references: [id])
  expires_at DateTime
  created_at DateTime @default(now())
}

model Microcontroller {
  id             Int                   @id @default(autoincrement())
  name           String
  api_key        String                @unique  // ✅ changed from Int to String
  created_at     DateTime              @default(now())
  isAC           Boolean               @default(false)
  sensor_data    SensorData[]          @relation("MicrocontrollerData")
  usage_sessions MachineUsageSession[]
}

model SensorData {
  id                 Int             @id @default(autoincrement())
  microcontroller_id Int
  microcontroller    Microcontroller @relation("MicrocontrollerData", fields: [microcontroller_id], references: [id])
  machine_state      Boolean
  timestamp          DateTime        @default(now())
  isAC               Boolean

  @@index([microcontroller_id, timestamp])  // ✅ added for query performance
}

model MachineUsageSession {
  id                 Int             @id @default(autoincrement())
  microcontroller_id Int
  microcontroller    Microcontroller @relation(fields: [microcontroller_id], references: [id])
  started_at         DateTime
  ended_at           DateTime?
  // ✅ removed duration_seconds — compute from ended_at - started_at instead

  @@index([microcontroller_id, ended_at])
  @@index([started_at])
}