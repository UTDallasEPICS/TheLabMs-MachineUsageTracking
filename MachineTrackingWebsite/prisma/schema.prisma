// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  user
}

model Microcontroller {
  id            Int          @id @default(autoincrement())
  name          String
  type          String
  api_key       Int          @unique
  battery_level Int
  created_at    DateTime     @default(now())
  sensor_data   SensorData[] @relation("MicrocontrollerData")
}

model SensorData {
  id                 Int             @id @default(autoincrement())
  microcontroller    Microcontroller @relation("MicrocontrollerData", fields: [microcontroller_id], references: [id], onDelete: Cascade)
  microcontroller_id Int
  machine_state      Boolean
  timestamp          DateTime        @default(now())

  @@index([microcontroller_id, timestamp], name: "idx_microcontroller_time")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password_hash String
  role          Role
  approved      Boolean   @default(false)
  created_at    DateTime  @default(now())
  sessions      Session[]
}

model Session {
  id         String   @id @default(cuid())
  user_id    String
  user       User     @relation(fields: [user_id], references: [id])
  expires_at DateTime
  created_at DateTime @default(now())
}